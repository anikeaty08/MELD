## SECTION 6 — HOW TO USE THE FRAMEWORK (Concrete Usage Guide)

### 6.1 The simple API (DeltaModel — already built)

```python
from meld.delta import DeltaModel
from torch.utils.data import DataLoader

# ── Create from scratch ────────────────────────────────────────────────────
model = DeltaModel.from_scratch(
    num_classes=10,
    backbone="resnet32",          # resnet20/32/44/56
    bound_tolerance=10.0,         # skip update if pre-bound exceeds this
    shift_threshold=0.3,          # KL score above which drift is flagged
)

# ── Or wrap your own backbone ──────────────────────────────────────────────
import torchvision.models as tv
bb = tv.resnet18(weights="IMAGENET1K_V1")
bb.fc = torch.nn.Identity()       # strip classifier, output = 512-d
model = DeltaModel.from_backbone(bb, out_dim=512, num_classes=10)

# ── Task 1: normal training ────────────────────────────────────────────────
result = model.update(loader_task1)
print(result)
# UpdateResult(task=0)
#   decision         : SAFE_DELTA
#   safe_to_deploy   : True
#   drift            : none  (score=0.0000)
#   bound pre → post : 0.0000 → 0.0000  held=True
#   compute saved    : 0.0%
#   epochs run       : 30

# ── Task 2: delta-only update, no old data needed ─────────────────────────
result = model.update(loader_task2)
print(result.decision)              # SAFE_DELTA
print(result.safe_to_deploy)        # True
print(result.compute_savings_pct)   # 74.3
print(result.drift_severity)        # "none"

# ── What to do with the decision ──────────────────────────────────────────
if result.decision == "SAFE_DELTA":
    deploy(model)                   # ship it
elif result.decision == "CAUTIOUS_DELTA":
    shadow_test(model)              # A/B test before shipping
elif result.decision in ("BOUND_VIOLATED", "SHIFT_CRITICAL"):
    trigger_full_retrain()          # fall back to full retrain
elif result.decision == "BOUND_EXCEEDED":
    pass                            # update was skipped automatically, old model still live

# ── Inference ─────────────────────────────────────────────────────────────
logits = model.predict(x)
labels = model.predict_labels(x)
embeddings = model.embed(x)         # for t-SNE / UMAP / retrieval

# ── Save and restore ──────────────────────────────────────────────────────
model.save("checkpoint.pt")
model = DeltaModel.load("checkpoint.pt")   # resumes from task 2, snapshot intact

# ── History ───────────────────────────────────────────────────────────────
print(model.summary())
# DeltaModel  tasks=2  classes=10  device=cpu
#   task  decision              drift  saved%   time  deploy
#   ────────────────────────────────────────────────────────
#      0  SAFE_DELTA            0.0000    0.0%   12.3s  ✓
#      1  SAFE_DELTA            0.1240   74.3%    4.1s  ✓
```

